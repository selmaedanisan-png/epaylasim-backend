generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CouponStatus {
  ACTIVE
  EXPIRED
  DEPLETED
  DISABLED
}

enum NotificationType {
  SYSTEM
  CAMPAIGN
  WISHLIST
  COUPON
  ADMIN
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum WishlistItemStatus {
  PENDING
  FUNDED
  EXPIRED
  CANCELLED
}

// ─── User ──────────────────────────────────────────────────────────────────

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  phone         String?     @unique
  username      String      @unique
  displayName   String
  passwordHash  String
  role          UserRole    @default(USER)
  status        UserStatus  @default(ACTIVE)
  avatarUrl     String?
  bio           String?
  emailVerified Boolean     @default(false)
  phoneVerified Boolean     @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  refreshTokens   RefreshToken[]
  wishlists       Wishlist[]
  campaigns       Campaign[]      @relation("CampaignOwner")
  contributions   Campaign[]      @relation("CampaignContributors")
  notifications   Notification[]
  couponUsages    CouponUsage[]
  analyticsEvents AnalyticsEvent[]
  payments        Payment[]

  @@index([email])
  @@index([username])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─── Wishlist ──────────────────────────────────────────────────────────────

model Wishlist {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  isPublic    Boolean  @default(true)
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items WishlistItem[]

  @@index([userId])
  @@index([slug])
  @@map("wishlists")
}

model WishlistItem {
  id           String             @id @default(uuid())
  wishlistId   String
  wishlist     Wishlist           @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  productUrl   String?
  imageUrl     String?
  targetAmount Decimal            @db.Decimal(10, 2)
  fundedAmount Decimal            @default(0) @db.Decimal(10, 2)
  status       WishlistItemStatus @default(PENDING)
  priority     Int                @default(0)
  expiresAt    DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  campaignItems CampaignItem[]

  @@index([wishlistId])
  @@index([status])
  @@map("wishlist_items")
}

// ─── Campaign ──────────────────────────────────────────────────────────────

model Campaign {
  id             String         @id @default(uuid())
  slug           String         @unique
  title          String
  description    String
  targetAmount   Decimal        @db.Decimal(10, 2)
  collectedAmount Decimal       @default(0) @db.Decimal(10, 2)
  status         CampaignStatus @default(DRAFT)
  coverImageUrl  String?
  ownerId        String
  owner          User           @relation("CampaignOwner", fields: [ownerId], references: [id])
  contributors   User[]         @relation("CampaignContributors")
  endsAt         DateTime?
  rejectionReason String?
  reviewedAt     DateTime?
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  items CampaignItem[]

  @@index([ownerId])
  @@index([status])
  @@index([slug])
  @@map("campaigns")
}

model CampaignItem {
  id             String       @id @default(uuid())
  campaignId     String
  campaign       Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  wishlistItemId String?
  wishlistItem   WishlistItem? @relation(fields: [wishlistItemId], references: [id])
  name           String
  amount         Decimal      @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())

  @@index([campaignId])
  @@map("campaign_items")
}

// ─── Coupon ────────────────────────────────────────────────────────────────

model Coupon {
  id              String       @id @default(uuid())
  code            String       @unique
  description     String?
  type            CouponType
  value           Decimal      @db.Decimal(10, 2)
  minOrderAmount  Decimal?     @db.Decimal(10, 2)
  maxDiscountAmount Decimal?   @db.Decimal(10, 2)
  usageLimit      Int?
  usedCount       Int          @default(0)
  perUserLimit    Int          @default(1)
  status          CouponStatus @default(ACTIVE)
  startsAt        DateTime     @default(now())
  expiresAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  usages CouponUsage[]

  @@index([code])
  @@index([status])
  @@map("coupons")
}

model CouponUsage {
  id         String   @id @default(uuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  discount   Decimal  @db.Decimal(10, 2)
  usedAt     DateTime @default(now())

  @@unique([couponId, userId])
  @@index([couponId])
  @@index([userId])
  @@map("coupon_usages")
}

// ─── Notification ──────────────────────────────────────────────────────────

model Notification {
  id        String              @id @default(uuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  data      Json?
  isRead    Boolean             @default(false)
  readAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Payment ───────────────────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id        String        @id @default(uuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  amount    Decimal       @db.Decimal(10, 2)
  status    PaymentStatus @default(PENDING)
  provider  String?
  createdAt DateTime      @default(now())

  @@index([userId])
  @@index([status])
  @@map("payments")
}

// ─── Contact ──────────────────────────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  repliedAt DateTime?
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@map("contact_messages")
}

// ─── Newsletter ───────────────────────────────────────────────────────────

model NewsletterSubscriber {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String?
  isActive       Boolean  @default(true)
  unsubscribedAt DateTime?
  createdAt      DateTime @default(now())

  @@index([email])
  @@index([isActive])
  @@map("newsletter_subscribers")
}

// ─── Contribution ─────────────────────────────────────────────────────────

model Contribution {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  email       String
  amount      Decimal  @db.Decimal(10, 2)
  wishItemId  String?
  wishItemName String?
  message     String?
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("contributions")
}

// ─── Admin Actions ─────────────────────────────────────────────────────────

model AdminAction {
  id          String   @id @default(uuid())
  adminEmail  String
  action      String
  targetUser  String?
  createdAt   DateTime @default(now())

  @@index([adminEmail])
  @@index([targetUser])
  @@map("admin_actions")
}

// ─── Analytics ─────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  event      String
  properties Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([createdAt])
  @@map("analytics_events")
}
